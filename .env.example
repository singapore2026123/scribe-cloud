# ---- Netlify environment variables (set these in Netlify dashboard: Site settings > Environment) ----

# Server-side only (used by Netlify functions; NEVER exposed to the browser)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# Optional extra free keys (separate Google AI Studio projects) to multiply quota — rotated automatically:
# GEMINI_API_KEY_2=...
# GEMINI_API_KEY_3=...

# Optional: self-hosted SeamlessM4T Burmese ASR (HF Space / Cloud Run). If set, Burmese transcription
# is routed here (free, unlimited, no Gemini quota); Gemini is the fallback. See hf-space/README.md.
# SCRIBE_ASR_URL=https://<you>-scribe-burmese-asr.hf.space

# Public client config (safe to expose; injected into the browser at build via /api/config)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key
