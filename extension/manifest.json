{
  "manifest_version": 3,
  "name": "Scribe Tab Audio",
  "version": "0.2.0",
  "description": "Live transcription + translation of the current tab's audio (no screen-share) in a side panel. Scribe.",
  "permissions": ["tabCapture", "offscreen", "tabs", "storage", "sidePanel", "activeTab"],
  "host_permissions": [
    "https://singapore2026123-scribe-burmese-asr.hf.space/*",
    "https://kanamic-scribe.netlify.app/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Scribe — open live side panel" },
  "side_panel": { "default_path": "sidepanel.html" }
}
